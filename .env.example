MONGODB_URI=mongodb://localhost:27017/k_statra
# MongoDB driver tuning (Atlas Flex friendly defaults)
# Keep pools small to reduce connection costs; increase if needed
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=0
MONGODB_MAX_IDLE_TIME_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
# Optional
PORT=4000
NODE_ENV=development
CORS_ORIGINS=*
RATE_LIMIT_MAX=120
LOG_LEVEL=debug
PAYMENTS_PROVIDER=xrpl-testnet
PAYMENTS_WEBHOOK_SECRET=change_me
XRPL_RPC_URL=wss://s.altnet.rippletest.net:51233
XRPL_DEST_ADDRESS=
# Optional for issued currencies on XRPL (e.g., RLUSD)
XRPL_ISSUED_CURRENCY_CODE=RLUSD
XRPL_ISSUER_ADDRESS=
ALLOW_ISSUED_XRPL=false
USE_XUMM_FOR_ISSUED=false
XUMM_API_KEY=
XUMM_API_SECRET=
XUMM_WEBHOOK_SECRET=
PAYMENTS_POLL_INTERVAL_MS=15000
PAYMENTS_POLL_BATCH=10
PAYMENTS_RATES_JSON={"USD":0.02,"KRW":0.000015}
ADMIN_TOKEN=change_admin_token
EMBEDDINGS_PROVIDER=mock
HF_API_TOKEN=
HF_EMBEDDING_MODEL=intfloat/multilingual-e5-small
HF_TIMEOUT_MS=20000
\n+# For OpenAI Embeddings (optional)
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=20000
MATCH_USE_EMBEDDING=false
MATCH_EMBEDDING_WEIGHT=0.3
WEBHOOK_RATE_LIMIT_MAX=30
PAYMENTS_CREATE_RATE_LIMIT_MAX=60
PAYMENTS_GUIDE_DEFAULT_LOCALE=ko
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENTS_ALLOWED_CURRENCIES=XRP,USD,KRW,EUR,JPY
ENABLE_CSP=false
METRICS_ROUTE_ALLOW=
METRICS_ROUTE_DENY=
METRICS_ROUTE_BANDS=false
METRICS_ROUTE_ALIAS_JSON={}
METRICS_ROUTE_ALIAS_RULES=[]
METRICS_MIN_SAMPLES_FOR_AVG=5
METRICS_SLOW_MS_THRESHOLD=300
METRICS_ERROR_RATE_THRESHOLD=0.1
METRICS_EVENTS_MAX=1000
METRICS_SAMPLE_WINDOW_MINUTES=60
